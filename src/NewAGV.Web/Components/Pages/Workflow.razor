@page "/workflow"
@using System.Net.Http
@using System.Threading
@inject AgvApiClient ApiClient
@inject DemoRoleState RoleState
@inject TelemetryClientService TelemetryClient
@implements IDisposable

<PageTitle>Workflow</PageTitle>

<section class="workflow-fit">
    <div class="workflow-page">
        <section class="workflow-topbar">
            <div class="workflow-topbar-controls">
                <div class="workflow-chip-row">
                    <span class="workflow-chip workflow-chip-primary"><i data-lucide="bot" class="workflow-chip-icon" aria-hidden="true"></i><span>Robot: @(_selectedRobotId ?? "None")</span></span>
                    <span class="workflow-chip workflow-chip-wide"><i data-lucide="workflow" class="workflow-chip-icon" aria-hidden="true"></i><span class="workflow-chip-label">Workflow:</span><strong>@(_selectedWorkflow?.Name ?? "None")</strong></span>
                    <span class="workflow-chip @GetWorkflowStateChipClass()"><i data-lucide="@GetWorkflowStateIcon()" class="workflow-chip-icon" aria-hidden="true"></i><span>@GetWorkflowStateLabel()</span></span>
                    <span class="workflow-chip workflow-chip-muted"><i data-lucide="list-ordered" class="workflow-chip-icon" aria-hidden="true"></i><span>@(_selectedWorkflow?.Steps.Count ?? 0) steps</span></span>
                    <span class="workflow-chip @(_isDirty ? "workflow-chip-warn" : "workflow-chip-ok")"><i data-lucide="@(_isDirty ? "circle-alert" : "clock")" class="workflow-chip-icon" aria-hidden="true"></i><span>@GetSaveStateLabel()</span></span>
                </div>

                <div class="workflow-toolbar-actions">
                    <button type="button" class="workflow-toolbar-button" @onclick="SaveAsync" disabled="@(!_canEdit || _isBusy)"><i data-lucide="save" class="workflow-button-icon" aria-hidden="true"></i><span>Save</span></button>
                    <button type="button" class="workflow-toolbar-button" @onclick="ValidateAsync" disabled="@(!_canEdit || _isBusy)"><i data-lucide="shield-check" class="workflow-button-icon" aria-hidden="true"></i><span>Validate</span></button>
                    <span class="workflow-toolbar-divider"></span>
                    <button type="button" class="workflow-toolbar-button workflow-toolbar-button-success" @onclick="RunAsync" disabled="@(!CanRun)"><i data-lucide="play" class="workflow-button-icon" aria-hidden="true"></i><span>Run</span></button>
                    <button type="button" class="workflow-toolbar-button workflow-toolbar-button-warning" @onclick="PauseAsync" disabled="@(!CanPause)"><i data-lucide="pause" class="workflow-button-icon" aria-hidden="true"></i><span>Pause</span></button>
                    <button type="button" class="workflow-toolbar-button" @onclick="ResumeAsync" disabled="@(!CanResume)"><i data-lucide="rotate-ccw" class="workflow-button-icon" aria-hidden="true"></i><span>Resume</span></button>
                    <button type="button" class="workflow-toolbar-button workflow-toolbar-button-danger" @onclick="CancelAsync" disabled="@(!CanCancel)"><i data-lucide="square" class="workflow-button-icon" aria-hidden="true"></i><span>Cancel</span></button>
                </div>
            </div>
        </section>

        @if (!string.IsNullOrWhiteSpace(_errorMessage))
        {
            <div class="workflow-validation-strip">
                <div class="workflow-validation-text"><strong>Workflow notice.</strong> @_errorMessage</div>
            </div>
        }

        <main class="workflow-workspace">
            <div class="workflow-layout">
                <aside class="workflow-sidebar">
                    <div class="workflow-sidebar-header">
                        <div class="workflow-sidebar-title">
                            <h2>Workflows</h2>
                            <span>@_workflows.Count total</span>
                        </div>
                        <label class="workflow-search">
                            <input placeholder="Search workflows..." @bind="_searchText" @bind:event="oninput" />
                        </label>
                    </div>

                    <div class="workflow-catalog-list">
                        @if (_isLoading)
                        {
                            <div class="workflow-empty-state">Loading workflows...</div>
                        }
                        else if (FilteredWorkflows.Count == 0)
                        {
                            <div class="workflow-empty-state">No workflows yet.</div>
                        }
                        else
                        {
                            @foreach (var workflow in FilteredWorkflows)
                            {
                                <button type="button" class="workflow-catalog-item @(workflow.Id == _selectedWorkflow?.Id ? "selected" : null)" @onclick="() => SelectWorkflowAsync(workflow.Id)">
                                    <div class="workflow-catalog-main">
                                        <div class="workflow-catalog-name">@workflow.Name</div>
                                        <div class="workflow-catalog-meta">@GetWorkflowCatalogMeta(workflow)</div>
                                    </div>
                                    <span class="workflow-status-chip @(workflow.IsPublished ? "workflow-status-ready" : "workflow-status-draft")">@(workflow.IsPublished ? "Published" : "Draft")</span>
                                </button>
                            }
                        }
                    </div>

                    <div class="workflow-sidebar-footer">
                        <button type="button" class="workflow-footer-btn workflow-footer-btn-primary" @onclick="CreateWorkflowAsync" disabled="@_isBusy">New</button>
                        <button type="button" class="workflow-footer-btn" @onclick="DuplicateWorkflowAsync" disabled="@(!_canEdit || _isBusy)">Duplicate</button>
                        <button type="button" class="workflow-footer-btn workflow-footer-btn-danger" @onclick="DeleteWorkflowAsync" disabled="@(!_canEdit || _isBusy)">Delete</button>
                    </div>
                </aside>

                <section class="workflow-editor">
                    @if (_selectedWorkflow is null)
                    {
                        <div class="workflow-empty-state">Select a workflow to view details.</div>
                    }
                    else
                    {
                        <div class="workflow-editor-header">
                            <div class="workflow-editor-title-group">
                                <div class="workflow-editor-title">
                                    <h2>@_selectedWorkflow.Name</h2>
                                    <span class="workflow-mini-chip">v@_selectedWorkflow.Version</span>
                                </div>
                                <p class="workflow-editor-desc">@(!string.IsNullOrWhiteSpace(_selectedWorkflow.Description) ? _selectedWorkflow.Description : "No description yet.")</p>
                            </div>
                            <div class="workflow-editor-meta">
                                <div>Assigned: <strong>@(string.IsNullOrWhiteSpace(_selectedWorkflow.AssignedRobotId) ? "Any robot" : _selectedWorkflow.AssignedRobotId)</strong></div>
                                <div>TaskChains from API: @_taskChains.Count</div>
                            </div>
                        </div>

                        @if (_validationResult is not null)
                        {
                            <div class="workflow-validation-strip">
                                <div class="workflow-validation-text"><strong>@GetValidationSummary()</strong> @GetValidationMessage()</div>
                                <button type="button" class="workflow-validation-btn" @onclick="ValidateAsync" disabled="@_isBusy">Re-validate</button>
                            </div>
                        }

                        <div class="workflow-canvas">
                            @if (_selectedWorkflow.Steps.Count == 0)
                            {
                                <div class="workflow-empty-state">No steps yet. Add a TaskChain step to start building this workflow.</div>
                            }
                            else
                            {
                                @foreach (var step in _selectedWorkflow.Steps.OrderBy(step => step.Sequence))
                                {
                                    <button type="button" class="workflow-step-card @(step.Id == _selectedStepId ? "selected" : null)" @onclick="() => SelectStep(step.Id)">
                                        <div class="workflow-step-index">@step.Sequence.ToString("00")</div>
                                        <div class="workflow-step-body">
                                            <div class="workflow-step-top">
                                                <span class="workflow-step-name">@(string.IsNullOrWhiteSpace(step.DisplayName) ? step.TaskChainName : step.DisplayName)</span>
                                                <span class="workflow-status-chip workflow-status-ready">@step.StepType</span>
                                            </div>
                                            <div class="workflow-step-meta">@GetStepMeta(step)</div>
                                        </div>
                                    </button>
                                }
                            }

                            <button type="button" class="workflow-add-step" @onclick="AddStep" disabled="@(!_canEdit || _isBusy)">Add TaskChain step</button>
                        </div>
                    }
                </section>

                <aside class="workflow-inspector">
                    <div class="workflow-tab-row">
                        <button type="button" class="workflow-tab @(_selectedTab == "Workflow" ? "active" : null)" @onclick='@(() => _selectedTab = "Workflow")'>Workflow</button>
                        <button type="button" class="workflow-tab @(_selectedTab == "Step" ? "active" : null)" @onclick='@(() => _selectedTab = "Step")'>Step</button>
                        <button type="button" class="workflow-tab @(_selectedTab == "Runtime" ? "active" : null)" @onclick='@(() => _selectedTab = "Runtime")'>Runtime</button>
                    </div>

                    <div class="workflow-inspector-body">
                        @if (_selectedWorkflow is null)
                        {
                            <div class="workflow-empty-state">No workflow selected.</div>
                        }
                        else if (_selectedTab == "Workflow")
                        {
                            <div class="workflow-side-shell">
                                <div class="workflow-runtime-section-title">Workflow</div>
                                <section class="workflow-side-card">
                                    <div class="workflow-form-panel">
                                        <div class="workflow-field">
                                            <label class="workflow-field-label">Workflow Name</label>
                                            <input class="workflow-input workflow-input-hero" @bind="_selectedWorkflow.Name" @bind:after="MarkDirty" />
                                        </div>
                                        <div class="workflow-field">
                                            <label class="workflow-field-label">Description</label>
                                            <textarea class="workflow-textarea workflow-textarea-hero" rows="4" @bind="_selectedWorkflow.Description" @bind:after="MarkDirty"></textarea>
                                        </div>
                                        <div class="workflow-field-grid workflow-field-grid-tight">
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">Assigned Robot</label>
                                                <div class="workflow-select-wrap">
                                                    <select class="workflow-select workflow-select-hero" @bind="_selectedWorkflow.AssignedRobotId" @bind:after="AssignedRobotChangedAsync">
                                                        <option value="">Any robot</option>
                                                        @foreach (var robot in _robots)
                                                        {
                                                            <option value="@robot.RobotId">@robot.RobotId</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">Execution Mode</label>
                                                <div class="workflow-select-wrap">
                                                    <select class="workflow-select workflow-select-hero" @bind="_selectedWorkflow.ExecutionMode" @bind:after="MarkDirty">
                                                        <option value="Sequential">Sequential</option>
                                                    </select>
                                                </div>
                                            </div>
                                        </div>
                                    </div>
                                </section>

                                <div class="workflow-runtime-section-title">Behavior</div>
                                <section class="workflow-side-card">
                                    <div class="workflow-toggle-list workflow-toggle-list-card">
                                        <label class="workflow-toggle">
                                            <div class="workflow-toggle-text">
                                                <div class="workflow-toggle-label">Stop on failure</div>
                                                <div class="workflow-toggle-hint">Halt workflow on first failed step.</div>
                                            </div>
                                            <div class="workflow-toggle-switch @(_selectedWorkflow.StopOnFailure ? "on" : null)">
                                                <input class="workflow-toggle-input" type="checkbox" @bind="_selectedWorkflow.StopOnFailure" @bind:after="MarkDirty" />
                                            </div>
                                        </label>
                                        <label class="workflow-toggle">
                                            <div class="workflow-toggle-text">
                                                <div class="workflow-toggle-label">Manual resume</div>
                                                <div class="workflow-toggle-hint">Operator must resume after pause events.</div>
                                            </div>
                                            <div class="workflow-toggle-switch @(_selectedWorkflow.ManualResume ? "on" : null)">
                                                <input class="workflow-toggle-input" type="checkbox" @bind="_selectedWorkflow.ManualResume" @bind:after="MarkDirty" />
                                            </div>
                                        </label>
                                        <label class="workflow-toggle">
                                            <div class="workflow-toggle-text">
                                                <div class="workflow-toggle-label">Require confirmation</div>
                                                <div class="workflow-toggle-hint">Prompt operator before run.</div>
                                            </div>
                                            <div class="workflow-toggle-switch @(_selectedWorkflow.RequiresConfirmation ? "on" : null)">
                                                <input class="workflow-toggle-input" type="checkbox" @bind="_selectedWorkflow.RequiresConfirmation" @bind:after="MarkDirty" />
                                            </div>
                                        </label>
                                    </div>
                                </section>
                            </div>
                        }
                        else if (_selectedTab == "Step")
                        {
                            @if (SelectedStep is null)
                            {
                                <div class="workflow-empty-state">Select a workflow step to edit it.</div>
                            }
                            else
                            {
                                <div class="workflow-side-shell">
                                    <div class="workflow-runtime-section-title">Step</div>
                                    <section class="workflow-side-card">
                                        <div class="workflow-form-panel workflow-step-panel">
                                            <div class="workflow-step-chip-row">
                                                <span class="workflow-step-chip workflow-step-chip-sequence">Step @SelectedStep.Sequence.ToString("00")</span>
                                                <span class="workflow-step-chip @GetSelectedStepStatusClass()">@GetSelectedStepStatusLabel()</span>
                                            </div>
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">Step Label</label>
                                                <input class="workflow-input workflow-input-hero" @bind="SelectedStep!.DisplayName" @bind:after="MarkDirty" />
                                            </div>
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">TaskChain</label>
                                                <div class="workflow-select-wrap">
                                                    <select class="workflow-select workflow-select-hero" @bind="SelectedStep!.TaskChainName" @bind:after="MarkDirty">
                                                        @foreach (var option in _taskChains)
                                                        {
                                                            <option value="@option.Name">@option.Name</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="workflow-field-grid workflow-field-grid-tight">
                                                <div class="workflow-field">
                                                    <label class="workflow-field-label">Timeout (s)</label>
                                                    <input class="workflow-input workflow-input-mono workflow-input-hero" type="number" @bind="SelectedStep!.TimeoutSeconds" @bind:after="MarkDirty" />
                                                </div>
                                                <div class="workflow-field">
                                                    <label class="workflow-field-label">Retry Count</label>
                                                    <input class="workflow-input workflow-input-mono workflow-input-hero" type="number" @bind="SelectedStep!.RetryCount" @bind:after="MarkDirty" />
                                                </div>
                                            </div>
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">On Failure</label>
                                                <div class="workflow-select-wrap">
                                                    <select class="workflow-select workflow-select-hero" @bind="SelectedStep!.FailurePolicy" @bind:after="MarkDirty">
                                                        @foreach (var policy in Enum.GetValues<WorkflowFailurePolicy>())
                                                        {
                                                            <option value="@policy">@GetFailurePolicyLabel(policy)</option>
                                                        }
                                                    </select>
                                                </div>
                                            </div>
                                            <div class="workflow-field">
                                                <label class="workflow-field-label">Note</label>
                                                <textarea class="workflow-textarea workflow-textarea-step" rows="2" placeholder="Optional operator note..." @bind="SelectedStep!.Note" @bind:after="MarkDirty"></textarea>
                                            </div>
                                        </div>
                                    </section>

                                    <div class="workflow-runtime-section-title">TaskChain Preview</div>
                                    <section class="workflow-side-card">
                                        <div class="workflow-preview-card workflow-step-preview-card">
                                            <div class="workflow-preview-head">
                                                <strong>@GetSelectedTaskChainName()</strong>
                                                <span class="workflow-step-preview-status">@GetSelectedTaskChainStatusLabel()</span>
                                            </div>
                                            <div class="workflow-preview-info">
                                                <span class="workflow-step-preview-dot"></span>
                                                <span>@GetSelectedTaskChainSummaryLine()</span>
                                            </div>
                                            <div class="workflow-preview-note">@GetSelectedTaskChainNote()</div>
                                        </div>
                                    </section>

                                    <div class="workflow-runtime-actions workflow-step-actions workflow-runtime-actions-panel">
                                        <button type="button" class="workflow-toolbar-button" @onclick="DuplicateStep" disabled="@_isBusy">Duplicate</button>
                                        <button type="button" class="workflow-toolbar-button workflow-toolbar-button-danger" @onclick="DeleteStep" disabled="@_isBusy">Delete</button>
                                    </div>
                                </div>
                            }
                        }
                        else
                        {
                            <div class="workflow-runtime-shell">
                                <section class="workflow-runtime-running @GetRuntimeRunSurfaceClass()">
                                    <div class="workflow-runtime-card-accent" aria-hidden="true"></div>
                                    <div class="workflow-runtime-running-head">
                                        <div class="workflow-runtime-running-copy">
                                            <div class="workflow-runtime-label">@GetRuntimeHeaderLabel()</div>
                                            <div class="workflow-runtime-name">@GetRuntimeWorkflowName()</div>
                                            <div class="workflow-runtime-sub">@GetRuntimeStartedSummary()</div>
                                        </div>
                                        <div class="workflow-runtime-elapsed workflow-runtime-pill">@GetRuntimeElapsed()</div>
                                    </div>
                                </section>

                                <div class="workflow-runtime-section-title">Active Step</div>
                                <section class="workflow-runtime-active @GetRuntimeStepSurfaceClass()">
                                    <div class="workflow-runtime-card-accent workflow-runtime-card-accent-step" aria-hidden="true"></div>
                                    <div class="workflow-runtime-active-head">
                                        <span class="workflow-runtime-step-title">@GetRuntimeStepTitle()</span>
                                        <span class="workflow-status-chip workflow-runtime-status-chip @GetRuntimeStepStatusClass()">
                                            <i data-lucide="circle" class="workflow-runtime-status-icon" aria-hidden="true"></i>
                                            <span>@GetRuntimeStepStatusLabel()</span>
                                        </span>
                                    </div>
                                    <div class="workflow-runtime-chain">@GetRuntimeStepChain()</div>
                                </section>

                                <div class="workflow-runtime-section-title">Progress</div>
                                <section class="workflow-runtime-progress">
                                    <div class="workflow-runtime-card-accent workflow-runtime-card-accent-progress" aria-hidden="true"></div>
                                    <div class="workflow-runtime-progress-head">
                                        <span class="workflow-runtime-progress-label">@GetRuntimeProgressLabel()</span>
                                        <span class="workflow-runtime-pct workflow-runtime-pill">@GetRuntimeProgressPercentText()</span>
                                    </div>
                                    <div class="workflow-progress-track">
                                        <span class="workflow-progress-fill" style="@GetRuntimeProgressStyle()"></span>
                                    </div>
                                </section>

                                <div class="workflow-runtime-section-title">Last Event</div>
                                <section class="workflow-runtime-event">
                                    <div class="workflow-runtime-card-accent workflow-runtime-card-accent-event" aria-hidden="true"></div>
                                    <div class="workflow-runtime-event-time">@GetRuntimeLastEventTime()</div>
                                    <div class="workflow-runtime-event-message">@GetRuntimeLastEventMessage()</div>
                                </section>

                                <div class="workflow-runtime-actions workflow-runtime-actions-panel">
                                    <button type="button" class="workflow-toolbar-button workflow-toolbar-button-warning" @onclick="PauseAsync" disabled="@(!CanPause)">
                                        <i data-lucide="pause" class="workflow-button-icon" aria-hidden="true"></i><span>Pause</span>
                                    </button>
                                    <button type="button" class="workflow-toolbar-button" @onclick="ResumeAsync" disabled="@(!CanResume)">
                                        <i data-lucide="rotate-ccw" class="workflow-button-icon" aria-hidden="true"></i><span>Resume</span>
                                    </button>
                                    <button type="button" class="workflow-toolbar-button workflow-toolbar-button-danger" @onclick="CancelAsync" disabled="@(!CanCancel)">
                                        <i data-lucide="square" class="workflow-button-icon" aria-hidden="true"></i><span>Cancel</span>
                                    </button>
                                </div>
                            </div>
                        }
                    </div>
                </aside>

                <section class="workflow-history @(_historyExpanded ? "expanded" : null)">
                    <div class="workflow-history-header">
                        <h2>Execution History</h2>
                        <span class="workflow-history-sub">Latest persisted workflow steps for @(_selectedRobotId ?? "all robots")</span>
                        <div class="workflow-history-spacer"></div>
                        <button type="button" class="workflow-history-toggle" @onclick="ToggleHistory">@(_historyExpanded ? "Collapse" : "Expand")</button>
                    </div>
                    <div class="workflow-history-scroll">
                        @if (_history.Count == 0)
                        {
                            <div class="workflow-empty-state">No workflow history yet.</div>
                        }
                        else
                        {
                            <table class="workflow-history-table">
                                <thead>
                                    <tr><th>Started</th><th>Workflow</th><th>Robot</th><th>Step</th><th>Status</th><th>Message</th></tr>
                                </thead>
                                <tbody>
                                    @foreach (var entry in _history)
                                    {
                                        <tr>
                                            <td>@entry.StartedAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                            <td class="workflow-history-cell-sans">@entry.WorkflowName</td>
                                            <td>@entry.RobotId</td>
                                            <td>@(entry.StepSequence is null ? "-" : $"{entry.StepSequence}: {entry.StepName}")</td>
                                            <td><span class="workflow-status-chip @GetHistoryStatusClass(entry.Status)">@entry.Status</span></td>
                                            <td class="workflow-history-cell-sans">@entry.Message</td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        }
                    </div>
                </section>
            </div>
        </main>
    </div>
</section>

@code {
    private readonly List<WorkflowSummaryDto> _workflows = [];
    private readonly List<RobotSummary> _robots = [];
    private readonly List<SeerTaskChainSummary> _taskChains = [];
    private readonly List<WorkflowHistoryEntryDto> _history = [];
    private WorkflowDetailDto? _selectedWorkflow;
    private WorkflowValidationResult? _validationResult;
    private WorkflowRunDto? _activeRun;
    private GatewayHealth? _gatewayHealth;
    private Guid? _selectedStepId;
    private string? _selectedRobotId;
    private string _searchText = string.Empty;
    private string _selectedTab = "Workflow";
    private string? _errorMessage;
    private bool _historyExpanded;
    private bool _isBusy;
    private bool _isDirty;
    private bool _isLoading = true;
    private Guid? _lastRuntimeRunId;
    private DateTimeOffset? _lastRuntimeEventAt;
    private string? _lastRuntimeEventMessage;
    private Timer? _runtimeClock;

    private IReadOnlyList<WorkflowSummaryDto> FilteredWorkflows => _workflows.Where(item => string.IsNullOrWhiteSpace(_searchText)
        || item.Name.Contains(_searchText, StringComparison.OrdinalIgnoreCase)
        || (item.Description?.Contains(_searchText, StringComparison.OrdinalIgnoreCase) ?? false)).ToList();

    private WorkflowStepDto? SelectedStep => _selectedWorkflow?.Steps.FirstOrDefault(step => step.Id == _selectedStepId)
        ?? _selectedWorkflow?.Steps.OrderBy(step => step.Sequence).FirstOrDefault();

    private bool _canEdit => _selectedWorkflow is not null;
    private bool CanRun => !_isBusy && _selectedWorkflow is not null && !string.IsNullOrWhiteSpace(_selectedRobotId) && _validationResult?.CanExecute == true && _activeRun is null;
    private bool CanPause => !_isBusy && _activeRun?.Status is WorkflowExecutionStatus.Starting or WorkflowExecutionStatus.Running;
    private bool CanResume => !_isBusy && _activeRun?.Status == WorkflowExecutionStatus.Paused;
    private bool CanCancel => !_isBusy && _activeRun is not null && _activeRun.Status is WorkflowExecutionStatus.Starting or WorkflowExecutionStatus.Running or WorkflowExecutionStatus.Paused;

    protected override async Task OnInitializedAsync()
    {
        await TelemetryClient.StartAsync();
        TelemetryClient.TelemetryReceived += HandleTelemetry;
        _runtimeClock = new Timer(_ =>
        {
            if (_selectedTab != "Runtime" || _activeRun is null)
            {
                return;
            }

            _ = InvokeAsync(StateHasChanged);
        }, null, TimeSpan.FromSeconds(1), TimeSpan.FromSeconds(1));
        await LoadAsync();
    }
    private async Task LoadAsync()
    {
        _isLoading = true;
        _errorMessage = null;
        try
        {
            _robots.Clear();
            _robots.AddRange(await ApiClient.GetRobotsAsync());
            _selectedRobotId ??= _robots.FirstOrDefault()?.RobotId;
            _taskChains.Clear();
            _taskChains.AddRange(await ApiClient.GetTaskChainsAsync());
            _gatewayHealth = await ApiClient.GetGatewayHealthAsync();
            await RefreshWorkflowListAsync();
            if (_workflows.Count > 0)
            {
                await SelectWorkflowAsync(_workflows[0].Id);
            }
            await RefreshRuntimeAsync();
        }
        catch (Exception exception) when (exception is HttpRequestException or InvalidOperationException)
        {
            _errorMessage = exception.Message;
        }
        finally
        {
            _isLoading = false;
        }
    }

    private async Task RefreshWorkflowListAsync()
    {
        _workflows.Clear();
        _workflows.AddRange(await ApiClient.GetWorkflowsAsync());
    }

    private async Task RefreshRuntimeAsync()
    {
        _activeRun = string.IsNullOrWhiteSpace(_selectedRobotId) ? null : await ApiClient.GetActiveWorkflowRunAsync(_selectedRobotId);
        _history.Clear();
        _history.AddRange(await ApiClient.GetWorkflowHistoryAsync(_selectedRobotId));

        if (_activeRun is null)
        {
            _lastRuntimeRunId = null;
            var latestEntry = _history.FirstOrDefault();
            _lastRuntimeEventAt = latestEntry?.CompletedAt ?? latestEntry?.StartedAt;
            _lastRuntimeEventMessage = latestEntry?.Message;
            return;
        }

        if (_lastRuntimeRunId != _activeRun.Id)
        {
            _lastRuntimeRunId = _activeRun.Id;
            _lastRuntimeEventAt = GetRuntimeEventTimestamp();
            _lastRuntimeEventMessage = GetFallbackRuntimeEventMessage();
        }
        else
        {
            _lastRuntimeEventAt ??= GetRuntimeEventTimestamp();
            _lastRuntimeEventMessage ??= GetFallbackRuntimeEventMessage();
        }
    }

