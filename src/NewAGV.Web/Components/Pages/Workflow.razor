    private string GetRuntimeProgressLabel()
    {
        if (_activeRun is null || _activeRun.Steps.Count == 0)
        {
            return "No active progress";
        }

        var currentStep = ActiveRunStep?.Sequence ?? _activeRun.CurrentStepSequence ?? Math.Min(_activeRun.Steps.Count, _activeRun.Steps.Count(step => step.Status == WorkflowStepExecutionStatus.Completed) + 1);
        return $"Step {Math.Clamp(currentStep, 1, _activeRun.Steps.Count)} of {_activeRun.Steps.Count}";
    }

    private double GetRuntimeProgressPercent()
    {
        if (_activeRun is null || _activeRun.Steps.Count == 0)
        {
            return 0;
        }

        if (_activeRun.Status == WorkflowExecutionStatus.Completed)
        {
            return 100;
        }

        if (ActiveRunStep?.ProgressPercent is double stepProgress)
        {
            return Math.Clamp(stepProgress, 0, 100);
        }

        var completedSteps = _activeRun.Steps.Count(step => step.Status == WorkflowStepExecutionStatus.Completed);
        return Math.Clamp((double)completedSteps / _activeRun.Steps.Count * 100, 0, 100);
    }

    private string GetRuntimeProgressPercentText() => $"{Math.Round(GetRuntimeProgressPercent())}%";
    private string GetRuntimeProgressStyle() => $"width: {GetRuntimeProgressPercent():0.##}%;";
