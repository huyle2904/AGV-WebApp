    private void AddStep()
    {
        if (_selectedWorkflow is null) return;
        var step = new WorkflowStepDto
        {
            Id = Guid.NewGuid(),
            Sequence = _selectedWorkflow.Steps.Count + 1,
            StepType = "TaskChain",
            TaskChainName = _taskChains.FirstOrDefault()?.Name ?? string.Empty,
            DisplayName = $"Step {_selectedWorkflow.Steps.Count + 1:00}",
            TimeoutSeconds = 60,
            RetryCount = 0,
            FailurePolicy = WorkflowFailurePolicy.StopWorkflow,
            StopOnFailure = true
        };
        _selectedWorkflow.Steps = _selectedWorkflow.Steps.Append(step).OrderBy(item => item.Sequence).ToList();
        _selectedStepId = step.Id;
        _selectedTab = "Step";
        MarkDirty();
    }

    private void DuplicateStep()
    {
        if (_selectedWorkflow is null || SelectedStep is null) return;
        var copy = new WorkflowStepDto
        {
            Id = Guid.NewGuid(),
            Sequence = SelectedStep.Sequence + 1,
            StepType = SelectedStep.StepType,
            TaskChainName = SelectedStep.TaskChainName,
            DisplayName = string.IsNullOrWhiteSpace(SelectedStep.DisplayName) ? null : $"{SelectedStep.DisplayName} Copy",
            TimeoutSeconds = SelectedStep.TimeoutSeconds,
            RetryCount = SelectedStep.RetryCount,
            FailurePolicy = SelectedStep.FailurePolicy,
            Note = SelectedStep.Note,
            StopOnFailure = SelectedStep.StopOnFailure,
            ParametersJson = SelectedStep.ParametersJson
        };
        var steps = _selectedWorkflow.Steps.ToList();
        steps.Insert(SelectedStep.Sequence, copy);
        NormalizeStepOrder(steps);
        _selectedWorkflow.Steps = steps;
        _selectedStepId = copy.Id;
        MarkDirty();
    }

    private void DeleteStep()
    {
        if (_selectedWorkflow is null || SelectedStep is null) return;
        var steps = _selectedWorkflow.Steps.Where(step => step.Id != SelectedStep.Id).ToList();
        NormalizeStepOrder(steps);
        _selectedWorkflow.Steps = steps;
        _selectedStepId = steps.FirstOrDefault()?.Id;
        MarkDirty();
    }

