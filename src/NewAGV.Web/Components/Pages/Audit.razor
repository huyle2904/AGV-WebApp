@page "/audit"
@implements IDisposable
@inject PlantStateService State

<PageTitle>Audit & Safety</PageTitle>

<h1>Audit & Safety</h1>
<p class="page-intro">Review live control policy, role restrictions, and recent robot command history.</p>

@if (!State.IsInitialized)
{
    <p class="empty-state">Loading audit trail...</p>
}
else
{
    <section class="panel-grid">
        <article class="panel">
            <div class="panel-header">
                <h2>Command policy matrix</h2>
            </div>

            <div class="table-shell">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>Command</th>
                            <th>Minimum role</th>
                            <th>Confirm</th>
                            <th>Description</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var policy in State.Policies)
                        {
                            <tr>
                                <td>@policy.CommandType</td>
                                <td>@policy.MinimumRole</td>
                                <td>@(policy.RequiresConfirmation ? "Required" : "Not required")</td>
                                <td>@policy.Description</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>

        <article class="panel">
            <div class="panel-header">
                <h2>Audit log</h2>
            </div>

            <div class="table-shell">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>Time</th>
                            <th>Robot</th>
                            <th>Command</th>
                            <th>Role</th>
                            <th>Status</th>
                            <th>Message</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entry in State.AuditEntries)
                        {
                            <tr>
                                <td>@entry.OccurredAt.ToLocalTime().ToString("HH:mm:ss")</td>
                                <td>@entry.RobotId</td>
                                <td>@entry.CommandType</td>
                                <td>@entry.RequestedByRole</td>
                                <td>@entry.Status</td>
                                <td>@entry.Message</td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>
    </section>
}

@code {
    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnStateChanged;
        await State.EnsureInitializedAsync();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
    }
}
