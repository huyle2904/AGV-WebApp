@page "/configuration"
@implements IDisposable
@inject PlantStateService State
@inject AgvApiClient ApiClient
@inject DemoRoleState RoleState

<PageTitle>Map Configuration</PageTitle>

<h1>Map Configuration</h1>
<p class="page-intro">Manage stations, zones, corridors, and waypoints used by command and navigation flows.</p>

@if (!State.IsInitialized)
{
    <p class="empty-state">Loading map configuration...</p>
}
else
{
    <section class="panel-grid">
        <article class="panel">
            <div class="panel-header">
                <h2>AGV gateway</h2>
                <span class="pill">@(_gatewayHealth?.Status.ToString() ?? "Unknown")</span>
            </div>

            @if (_gatewayHealth is null)
            {
                <p class="empty-state">Gateway status has not been checked.</p>
            }
            else
            {
                <dl class="detail-list">
                    <div>
                        <dt>Base URL</dt>
                        <dd>@(_gatewayHealth.BaseUrl.Length == 0 ? "Not configured" : _gatewayHealth.BaseUrl)</dd>
                    </div>
                    <div>
                        <dt>Host</dt>
                        <dd>@(_gatewayHealth.Host.Length == 0 ? "-" : $"{_gatewayHealth.Host}:{_gatewayHealth.Port}")</dd>
                    </div>
                    <div>
                        <dt>HTTP</dt>
                        <dd>@(_gatewayHealth.HttpStatusCode?.ToString() ?? "-")</dd>
                    </div>
                    <div>
                        <dt>Checked</dt>
                        <dd>@_gatewayHealth.CheckedAt.ToLocalTime().ToString("HH:mm:ss")</dd>
                    </div>
                </dl>
                <p class="inline-status">@_gatewayHealth.Message</p>
            }

            <button class="secondary-button" type="button" @onclick="CheckGatewayAsync">Check gateway</button>
        </article>

        <article class="panel">
            <div class="panel-header">
                <h2>Entity editor</h2>
                <span class="pill">@RoleState.CurrentRole</span>
            </div>

            <EditForm Model="_entity" OnValidSubmit="SaveAsync" class="command-form">
                <div class="two-column">
                    <label>
                        <span>Entity id</span>
                        <input @bind="_entity.EntityId" placeholder="Auto if empty" />
                    </label>
                    <label>
                        <span>Name</span>
                        <input @bind="_entity.Name" />
                    </label>
                </div>

                <div class="two-column">
                    <label>
                        <span>Type</span>
                        <select @bind="_entity.Type">
                            @foreach (var type in Enum.GetValues<MapEntityType>())
                            {
                                <option value="@type">@type</option>
                            }
                        </select>
                    </label>
                    <label>
                        <span>Color</span>
                        <input @bind="_entity.Color" />
                    </label>
                </div>

                <div class="two-column">
                    <label>
                        <span>X</span>
                        <input type="number" step="0.1" @bind="_entity.X" />
                    </label>
                    <label>
                        <span>Y</span>
                        <input type="number" step="0.1" @bind="_entity.Y" />
                    </label>
                </div>

                <div class="two-column">
                    <label>
                        <span>Width</span>
                        <input type="number" step="0.1" @bind="_entity.Width" />
                    </label>
                    <label>
                        <span>Height</span>
                        <input type="number" step="0.1" @bind="_entity.Height" />
                    </label>
                </div>

                <button class="primary-button" type="submit">Save entity</button>
            </EditForm>

            @if (!string.IsNullOrWhiteSpace(_message))
            {
                <p class="inline-status">@_message</p>
            }
        </article>

        <article class="panel">
            <div class="panel-header">
                <h2>Published map objects</h2>
            </div>
            <div class="table-shell">
                <table class="app-table">
                    <thead>
                        <tr>
                            <th>Entity</th>
                            <th>Type</th>
                            <th>Version</th>
                            <th></th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var entity in State.MapEntities)
                        {
                            <tr>
                                <td>@entity.Name</td>
                                <td>@entity.Type</td>
                                <td>@entity.Version</td>
                                <td class="actions-cell">
                                    <button class="secondary-button" @onclick="() => Edit(entity)">Edit</button>
                                    <button class="danger-button" @onclick="() => DeleteAsync(entity.EntityId)">Delete</button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </article>
    </section>
}

@code {
    private MapEntity _entity = new(string.Empty, MapEntityType.Station, "New station", 24, 24, 8, 8, "#f8fafc", 1);
    private string? _message;
    private GatewayHealth? _gatewayHealth;

    protected override async Task OnInitializedAsync()
    {
        State.Changed += OnStateChanged;
        await State.EnsureInitializedAsync();
        await CheckGatewayAsync();
    }

    private void Edit(MapEntity entity)
    {
        _entity = entity with { Properties = entity.Properties is null ? null : new Dictionary<string, string>(entity.Properties) };
    }

    private async Task SaveAsync()
    {
        var saved = await ApiClient.UpsertMapEntityAsync(_entity, RoleState.CurrentRole);
        _message = $"Saved {saved.Name} as version {saved.Version}.";
        _entity = new MapEntity(string.Empty, MapEntityType.Station, "New station", 24, 24, 8, 8, "#f8fafc", 1);
        await State.RefreshMapAsync();
    }

    private async Task DeleteAsync(string entityId)
    {
        await ApiClient.DeleteMapEntityAsync(entityId, RoleState.CurrentRole);
        _message = $"Deleted {entityId}.";
        await State.RefreshMapAsync();
    }

    private async Task CheckGatewayAsync()
    {
        _gatewayHealth = await ApiClient.GetGatewayHealthAsync();
    }

    private void OnStateChanged() => InvokeAsync(StateHasChanged);

    public void Dispose()
    {
        State.Changed -= OnStateChanged;
    }
}
