@inherits LayoutComponentBase
@implements IDisposable
@inject DemoRoleState RoleState
@inject NavigationManager Navigation

<div class="page @(IsSidebarCollapsed ? "sidebar-collapsed" : null)">
    <div class="sidebar">
        <NavMenu IsCollapsed="IsSidebarCollapsed" OnCollapseChanged="SetSidebarCollapsed" />
    </div>

    <main>
        <div class="top-row px-4">
            <div class="topbar-brand">
                <span class="topbar-title">IDEA AGV CONTROL</span>
                <span class="topbar-subtitle">@CurrentPageTitle</span>
            </div>
            <div class="topbar-actions">
                <label class="role-switcher">
                    <span>Role</span>
                    <select value="@RoleState.CurrentRole" @onchange="OnRoleChanged">
                        @foreach (var role in Enum.GetValues<UserRole>())
                        {
                            <option value="@role">@role</option>
                        }
                    </select>
                </label>
                <button type="button" class="user-avatar" title="Tai khoan operator" aria-label="Tai khoan operator"></button>
            </div>
        </div>

        <article class="content px-4">
            @Body
        </article>
    </main>
</div>

<div id="blazor-error-ui">
    An unhandled error has occurred.
    <a href="" class="reload">Reload</a>
    <a class="dismiss">x</a>
</div>

@code {
    private bool IsSidebarCollapsed { get; set; }

    private string CurrentPageTitle => GetPageTitle();

    protected override void OnInitialized()
    {
        Navigation.LocationChanged += OnLocationChanged;
    }

    private Task SetSidebarCollapsed(bool isCollapsed)
    {
        IsSidebarCollapsed = isCollapsed;
        return Task.CompletedTask;
    }

    private void OnRoleChanged(ChangeEventArgs args)
    {
        if (Enum.TryParse<UserRole>(args.Value?.ToString(), out var role))
        {
            RoleState.SetRole(role);
        }
    }

    private void OnLocationChanged(object? sender, Microsoft.AspNetCore.Components.Routing.LocationChangedEventArgs args)
        => InvokeAsync(StateHasChanged);

    private string GetPageTitle()
    {
        var relative = Navigation.ToBaseRelativePath(Navigation.Uri).Split('?', '#')[0].Trim('/').ToLowerInvariant();
        return relative switch
        {
            "" => "Trang chu",
            "map" => "AGV Monitor",
            "commands" => "Lenh",
            "taskchains" => "TaskChain",
            "workflow" => "Workflow",
            _ => "AGV Monitor"
        };
    }

    public void Dispose()
    {
        Navigation.LocationChanged -= OnLocationChanged;
    }
}
