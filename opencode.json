{
  "$schema": "https://opencode.ai/config.json",
  "agent": {
    "build": {
      "mode": "primary",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "allow",
        "bash": "allow"
      }
    },
    "plan": {
      "mode": "primary",
      "model": "openai/gpt-5.5",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff": "allow",
          "git log*": "allow",
          "grep *": "allow",
          "dotnet build*": "allow",
          "dotnet test*": "allow"
        }
      }
    },
    "code-reviewer": {
      "description": "Reviews code for bugs, security, and performance issues",
      "mode": "subagent",
      "model": "opencode/mimo-v2.5-free",
      "permission": {
        "edit": "deny",
        "bash": {
          "*": "deny",
          "git diff": "allow",
          "git log*": "allow",
          "grep *": "allow"
        }
      }
    }
  }
}
